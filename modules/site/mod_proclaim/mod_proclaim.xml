<?xml version="1.0" encoding="utf-8"?>
<extension type="module" method="upgrade" client="site">
    <name>mod_proclaim</name>
    <author>CWM Team</author>
    <authorEmail>info@christianwebministries.org</authorEmail>
    <authorUrl>www.christianwebministries.org</authorUrl>
    <copyright>(C) 2026 Proclaim All rights reserved.</copyright>
    <version>10.1.0-rc2-dev</version>
    <creationDate>Jan 29, 2026</creationDate>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <description>MOD_PROCLAIM_DESCRIPTION</description>
    <namespace path="src">CWM\Module\Proclaim</namespace>
    <files>
        <folder module="mod_proclaim">services</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
        <folder>src</folder>
    </files>
    <config>
        <fields name="params" addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
            <fieldset name="basic">
                <field name="dummy" type="LoadLanguageFile" default=""/>
                <field name="t" type="sql" label="JBS_MDL_SELECT_TEMPLATE"
                       description="JBS_MDL_SELECT_TEMPLATE_DESC" default="1"
                       class="form-select"
                       query="SELECT id, title FROM #__bsms_templates WHERE published = 1 ORDER BY title ASC"
                       key_field="id" value_field="title" required="true"/>
                <field name="moduletemplate" type="sql" label="JBS_MDL_TEMPLATE"
                       description="JBS_MDL_TEMPLATE_DESC" hide_none="true"
                       class="form-select"
                       query="SELECT id, type, filename FROM #__bsms_templatecode WHERE type=7 AND published =1 ORDER BY filename ASC"
                       key_field="filename" value_field="filename">
                    <option value="0">JBS_CMN_USE_DEFAULT</option>
                </field>
                <field name="simple_mode" type="radio"
                       layout="joomla.form.field.radio.switcher"
                       default="0"
                       label="JBS_MDL_SIMPLE_MODE"
                       description="JBS_MDL_SIMPLE_MODE_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="show_media" type="radio"
                       layout="joomla.form.field.radio.switcher"
                       default="1"
                       label="JBS_MDL_SHOW_MEDIA"
                       description="JBS_MDL_SHOW_MEDIA_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="moduleitems" type="number"
                       default="5"
                       min="1"
                       max="100"
                       class="form-control"
                       label="JBS_MDL_ITEMS"
                       description="JBS_MDL_ITEMS_DESC"/>
                <field name="use_headers_list" type="radio"
                       layout="joomla.form.field.radio.switcher"
                       default="1"
                       label="JBS_MDL_USE_LIST_HEADER"
                       description="JBS_MDL_USE_LIST_HEADER_DESC">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="show_link" type="radio"
                       layout="joomla.form.field.radio.switcher"
                       default="1"
                       label="JBS_MDL_SHOW_COMPONENT"
                       description="JBS_MDL_SHOW_COMPONENT_DESC">
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field name="pagetext" type="text"
                       default="More Messages"
                       class="form-control"
                       label="JBS_MDL_LINK_TEXT"
                       description="JBS_MDL_LINK_TEXT_DESC"/>
            </fieldset>
            <fieldset name="JBS_MDL_FILTERS" label="JBS_MDL_FILTERS">
                <field name="order"
                       type="list"
                       label="JBS_CMN_ORDERING"
                       description="JBS_CMN_ORDERING_DESC"
                       class="form-select"
                       default="">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="1">JBS_CMN_DESCENDING</option>
                    <option value="2">JBS_CMN_ASCENDING</option>
                </field>
                <field name="condition"
                       type="list"
                       label="JBS_MDL_AND_OR"
                       description="JBS_MDL_AND_OR_DESC"
                       class="form-select"
                       default="0">
                    <option value="0">JBS_MDL_OR</option>
                    <option value="1">JBS_MDL_AND</option>
                </field>
                <field name="language" type="contentlanguage" class="form-select"
                       label="JFIELD_LANGUAGE_LABEL" description="JBS_MDL_LANGUAGE_DESC">
                    <option value="*">JALL</option>
                </field>
                <field name="teacher_id" type="TeacherList" multiple="true" default=""
                       class="form-select"
                       label="JBS_CMN_FILTERS_TEACHER" description="JBS_CMN_FILTERS_DESC">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>
                <field name="series_id" type="Series" multiple="true" default=""
                       class="form-select"
                       label="JBS_CMN_FILTERS_SERIES" description="JBS_CMN_FILTERS_DESC">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>
                <field name="booknumber" type="SQL" multiple="true" translate="true"
                       class="form-select"
                       label="JBS_CMN_FILTERS_BOOKS" description="JBS_CMN_FILTERS_DESC"
                       query="SELECT booknumber, bookname FROM #__bsms_books WHERE published = 1 ORDER BY booknumber ASC"
                       key_field="booknumber" value_field="bookname"
                       default="">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>
                <field name="topic_id" type="TopicsList" multiple="true"
                       class="form-select"
                       label="JBS_CMN_FILTERS_TOPICS" description="JBS_CMN_FILTERS_DESC"
                       default="">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>

                <field name="locations" type="Locations" multiple="true"
                       class="form-select"
                       label="JBS_CMN_FILTERS_LOCATIONS" description="JBS_CMN_FILTERS_DESC"
                       default="">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>

                <field name="location_filter"
                       type="list"
                       default="all"
                       class="form-select"
                       label="JBS_MDL_LOCATION_FILTER"
                       description="JBS_MDL_LOCATION_FILTER_DESC">
                    <option value="all">JBS_MDL_LOCATION_FILTER_ALL</option>
                    <option value="specific">JBS_MDL_LOCATION_FILTER_SPECIFIC</option>
                    <option value="user">JBS_MDL_LOCATION_FILTER_USER</option>
                </field>

                <field name="specific_location"
                       type="LocationList"
                       showon="location_filter:specific"
                       class="form-select"
                       label="JBS_MDL_SPECIFIC_LOCATION"
                       description="JBS_MDL_SPECIFIC_LOCATION_DESC">
                    <option value="-1">JBS_CMN_SELECT_LOCATION</option>
                </field>
                <field name="messagetype" type="MessageTypeList" multiple="true"
                       class="form-select"
                       label="JBS_CMN_FILTERS_MESSAGETYPES" description="JBS_CMN_FILTERS_DESC"
                       default="">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>

                <field name="year" type="sql" default="" multiple="true"
                       class="form-select"
                       label="JBS_CMN_FILTERS_YEARS" description="JBS_CMN_FILTERS_DESC"
                       query="SELECT DISTINCT(YEAR(studydate)) as date FROM #__bsms_studies ORDER BY studydate DESC"
                       key_field="date" value_field="date">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="-1">JBS_CMN_SHOW_ALL</option>
                </field>
            </fieldset>
            <fieldset name="JBS_MDL_MEDIA" label="JBS_MDL_MEDIA">
                <field name="player" type="list" label="JBS_MED_PLAYER"
                       description="JBS_MED_PLAYER_DESC" default="" class="form-select">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">JBS_CMN_DIRECT_LINK</option>
                    <option value="1">JBS_CMN_USE_INTERNAL_PLAYER</option>
                    <option value="3">JBS_CMN_USE_AV</option>
                    <option value="7">JBS_CMN_USE_MP3_PLAYER</option>
                    <option value="8">JBS_CMN_USE_EMBED_CODE</option>
                </field>
                <field name="popup" type="list" label="JBS_MED_INTERNAL_POPUP"
                       description="JBS_MED_INTERNAL_POPUP_DESC"
                       default="" class="form-select">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="1">JBS_CMN_POPUP</option>
                    <option value="2">JBS_CMN_INLINE</option>
                    <option value="3">JBS_CMN_SQUEEZEBOX</option>
                </field>
                <field name="player_width" type="number"
                       default="400"
                       min="100"
                       max="1920"
                       class="form-control"
                       label="JBS_TPL_MEDIA_PLAYER_WIDTH"
                       description="JBS_TPL_MEDIA_PLAYER_WIDTH_DESC"/>
                <field name="player_height" type="number"
                       default="300"
                       min="100"
                       max="1080"
                       class="form-control"
                       label="JBS_TPL_MEDIA_PLAYER_HEIGHT"
                       description="JBS_TPL_MEDIA_PLAYER_HEIGHT_DESC"/>
                <field name="embedshare" default="" type="list" class="form-select"
                       label="JBS_TPL_MEDIA_EMBEDSHARE" description="JBS_TPL_MEDIA_EMBEDSHARE_DESC">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="FALSE">JBS_TPL_NO_SHARE</option>
                    <option value="TRUE">JBS_TPL_SHOW_SHARE</option>
                </field>
                <field name="backcolor" type="ColorPicker"
                       default="#287585"
                       label="JBS_TPL_MEDIA_BACKCOLOR"
                       description="JBS_TPL_MEDIA_BACKCOLOR_DESC"/>
                <field name="frontcolor" type="ColorPicker"
                       default="white"
                       label="JBS_TPL_MEDIA_FRONTCOLOR"
                       description="JBS_TPL_MEDIA_FRONTCOLOR_DESC"/>
                <field name="lightcolor" type="ColorPicker"
                       default="black"
                       label="JBS_TPL_MEDIA_LIGHTCOLOR"
                       description="JBS_TPL_MEDIA_LIGHTCOLOR_DESC"/>
                <field name="screencolor" type="ColorPicker"
                       default="black"
                       label="JBS_TPL_MEDIA_SCREENCOLOR"
                       description="JBS_TPL_MEDIA_SCREENCOLOR_DESC"/>
                <field name="popuptitle" type="Custom" codeset="template" input="text"
                       default="{{title}}"
                       size="75"
                       label="JBS_MED_MEDIA_POPUPTITLE"
                       description="JBS_TPL_MEDIA_POPUPTITLE_FOOTER_DESC"/>
                <field name="popupfooter" type="Custom" codeset="template" input="text"
                       default=""
                       size="75"
                       label="JBS_MED_MEDIA_POPUPFOOTER"
                       description="JBS_TPL_MEDIA_POPUPTITLE_FOOTER_DESC"/>
                <field name="popupmargin" type="number"
                       default="50"
                       min="0"
                       max="200"
                       class="form-control"
                       label="JBS_MED_MEDIA_POPUPMARGIN"
                       description="JBS_TPL_MEDIA_POPUPMARGIN_DESC"/>
                <field name="popupbackground" type="ColorPicker"
                       default="black"
                       label="JBS_TPL_MEDIA_POPUPBACKGROUND"
                       description="JBS_TPL_MEDIA_POPUPBACKGROUND_DESC"/>
                <field name="popupimage" type="media"
                       default="media/com_proclaim/images/speaker24.png"
                       directory="com_proclaim/images"
                       label="JBS_TPL_MEDIA_POPUPIMAGE"
                       description="JBS_TPL_MEDIA_POPUPIMAGE_DESC"/>
                <field name="media_popout_yes" type="list"
                       default="1"
                       class="form-select"
                       label="JBS_MED_MEDIA_POPOUT_YES"
                       description="JBS_MED_MEDIA_POPOUT_YES_DESC">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="media_popout_text" type="text"
                       default=""
                       class="form-control"
                       placeholder="Text to use for pop out button"
                       label="JBS_MED_MEDIA_POPOUT_TEXT"
                       description="JBS_MED_MEDIA_POPOUT_TEXT_DESC"/>
                <field name="show_filesize" type="list" default="" class="form-select"
                       label="JBS_TPL_MEDIA_SHOW_FILESIZE" description="JBS_TPL_MEDIA_SHOW_FILESIZE_DESC">
                    <option value="">JGLOBAL_USE_GLOBAL</option>
                    <option value="0">JBS_CMN_HIDE</option>
                    <option value="1">JBS_TPL_SHOW_FILESIZE</option>
                    <option value="2">JBS_TPL_SHOW_COMMENT</option>
                    <option value="3">JBS_TPL_SHOW_COMMENT_OR_FILESIZE</option>
                </field>
            </fieldset>
            <fieldset name="JBS_MDL_MORE_SETTINGS" label="JBS_MDL_MORE_SETTINGS">
                <field name="use_headers_module" type="list" default="" class="form-select"
                       label="JBS_TPL_LISTITEMS_USE_HEADERS_LIST" description="JBS_TPL_LISTITEMS_USE_HEADERS_LIST_DESC">
                    <option value="0">JBS_TPL_NO_HEADER_ROW</option>
                    <option value="1">JBS_TPL_USE_HEADER_ROW</option>
                </field>
                <field name="pageheader" filter="raw" type="editor" rows="10" buttons="true"
                       cols="75" label="JBS_MDL_HEADER_TEXT" description="JBS_MDL_HEADER_TEXT_DESC"/>
                <field name="stylesheet" type="text"
                       default=""
                       class="form-control"
                       label="JBS_TPL_VERSES_STYLESHEET"
                       description="JBS_TPL_VERSES_STYLESHEET_DESC"/>
            </fieldset>
            <fieldset name="JBS_MDL_LAYOUT_EDITOR" label="JBS_MDL_LAYOUT_EDITOR">
                <field name="layout_editor" type="LayoutEditor"
                       context="messages"
                       show-view-settings="false"
                       lazy="true"
                       hiddenLabel="true"/>
                <!-- Hidden fields for layout data storage - managed by Layout Editor -->
                <field name="scripture1row" type="hidden" default="1"/>
                <field name="scripture1col" type="hidden" default="1"/>
                <field name="scripture1colspan" type="hidden" default="0"/>
                <field name="scripture1element" type="hidden" default="1"/>
                <field name="scripture1custom" type="hidden" default=""/>
                <field name="scripture1linktype" type="hidden" default="0"/>
                <field name="scripture1show_verses" type="hidden" default=""/>
                <field name="scripture2row" type="hidden" default="0"/>
                <field name="scripture2col" type="hidden" default="1"/>
                <field name="scripture2colspan" type="hidden" default="0"/>
                <field name="scripture2element" type="hidden" default="1"/>
                <field name="scripture2custom" type="hidden" default=""/>
                <field name="scripture2linktype" type="hidden" default="0"/>
                <field name="scripture2show_verses" type="hidden" default=""/>
                <field name="secondaryrow" type="hidden" default="0"/>
                <field name="secondarycol" type="hidden" default="1"/>
                <field name="secondarycolspan" type="hidden" default="0"/>
                <field name="secondaryelement" type="hidden" default="1"/>
                <field name="secondarycustom" type="hidden" default=""/>
                <field name="secondarylinktype" type="hidden" default="0"/>
                <field name="secondaryshow_verses" type="hidden" default=""/>
                <field name="jbsmediarow" type="hidden" default="1"/>
                <field name="jbsmediacol" type="hidden" default="1"/>
                <field name="jbsmediacolspan" type="hidden" default="1"/>
                <field name="jbsmediaelement" type="hidden" default="1"/>
                <field name="jbsmediacustom" type="hidden" default=""/>
                <field name="jbsmedialinktype" type="hidden" default="0"/>
                <!-- Title, Date, Teacher fields -->
                <field name="titlerow" type="hidden" default="1"/>
                <field name="titlecol" type="hidden" default="1"/>
                <field name="titlecolspan" type="hidden" default="2"/>
                <field name="titleelement" type="hidden" default="1"/>
                <field name="titlecustom" type="hidden" default=""/>
                <field name="titlelinktype" type="hidden" default="0"/>
                <field name="daterow" type="hidden" default="1"/>
                <field name="datecol" type="hidden" default="1"/>
                <field name="datecolspan" type="hidden" default="1"/>
                <field name="dateelement" type="hidden" default="1"/>
                <field name="datecustom" type="hidden" default=""/>
                <field name="datelinktype" type="hidden" default="0"/>
                <field name="datedate_format" type="hidden" default=""/>
                <field name="teacherrow" type="hidden" default="0"/>
                <field name="teachercol" type="hidden" default="1"/>
                <field name="teachercolspan" type="hidden" default="0"/>
                <field name="teacherelement" type="hidden" default="1"/>
                <field name="teachercustom" type="hidden" default=""/>
                <field name="teacherlinktype" type="hidden" default="0"/>
                <field name="teacherimagerow" type="hidden" default="0"/>
                <field name="teacherimagecol" type="hidden" default="1"/>
                <field name="teacherimagecolspan" type="hidden" default="0"/>
                <field name="teacherimageelement" type="hidden" default="1"/>
                <field name="teacherimagecustom" type="hidden" default=""/>
                <field name="teacherimagelinktype" type="hidden" default="0"/>
                <field name="teacher-titlerow" type="hidden" default="0"/>
                <field name="teacher-titlecol" type="hidden" default="1"/>
                <field name="teacher-titlecolspan" type="hidden" default="0"/>
                <field name="teacher-titleelement" type="hidden" default="1"/>
                <field name="teacher-titlecustom" type="hidden" default=""/>
                <field name="teacher-titlelinktype" type="hidden" default="0"/>
                <!-- Duration, Study Intro, Series fields -->
                <field name="durationrow" type="hidden" default="0"/>
                <field name="durationcol" type="hidden" default="1"/>
                <field name="durationcolspan" type="hidden" default="0"/>
                <field name="durationelement" type="hidden" default="1"/>
                <field name="durationcustom" type="hidden" default=""/>
                <field name="durationlinktype" type="hidden" default="0"/>
                <field name="studyintrorow" type="hidden" default="2"/>
                <field name="studyintrocol" type="hidden" default="1"/>
                <field name="studyintrocolspan" type="hidden" default="6"/>
                <field name="studyintroelement" type="hidden" default="1"/>
                <field name="studyintrocustom" type="hidden" default=""/>
                <field name="studyintrolinktype" type="hidden" default="0"/>
                <field name="seriesrow" type="hidden" default="0"/>
                <field name="seriescol" type="hidden" default="1"/>
                <field name="seriescolspan" type="hidden" default="0"/>
                <field name="serieselement" type="hidden" default="1"/>
                <field name="seriescustom" type="hidden" default=""/>
                <field name="serieslinktype" type="hidden" default="0"/>
                <field name="seriesthumbnailrow" type="hidden" default="0"/>
                <field name="seriesthumbnailcol" type="hidden" default="1"/>
                <field name="seriesthumbnailcolspan" type="hidden" default="0"/>
                <field name="seriesthumbnailelement" type="hidden" default="1"/>
                <field name="seriesthumbnailcustom" type="hidden" default=""/>
                <field name="seriesthumbnaillinktype" type="hidden" default="0"/>
                <field name="seriesdescriptionrow" type="hidden" default="0"/>
                <field name="seriesdescriptioncol" type="hidden" default="1"/>
                <field name="seriesdescriptioncolspan" type="hidden" default="0"/>
                <field name="seriesdescriptionelement" type="hidden" default="1"/>
                <field name="seriesdescriptioncustom" type="hidden" default=""/>
                <field name="seriesdescriptionlinktype" type="hidden" default="0"/>
                <!-- Submitted, Hits, Downloads fields -->
                <field name="submittedrow" type="hidden" default="0"/>
                <field name="submittedcol" type="hidden" default="1"/>
                <field name="submittedcolspan" type="hidden" default="0"/>
                <field name="submittedelement" type="hidden" default="1"/>
                <field name="submittedcustom" type="hidden" default=""/>
                <field name="submittedlinktype" type="hidden" default="0"/>
                <field name="hitsrow" type="hidden" default="0"/>
                <field name="hitscol" type="hidden" default="1"/>
                <field name="hitscolspan" type="hidden" default="6"/>
                <field name="hitselement" type="hidden" default="1"/>
                <field name="hitscustom" type="hidden" default=""/>
                <field name="hitslinktype" type="hidden" default="0"/>
                <field name="downloadsrow" type="hidden" default="0"/>
                <field name="downloadscol" type="hidden" default="1"/>
                <field name="downloadscolspan" type="hidden" default="0"/>
                <field name="downloadselement" type="hidden" default="1"/>
                <field name="downloadscustom" type="hidden" default=""/>
                <field name="downloadslinktype" type="hidden" default="0"/>
                <!-- Study Number, Topic, Locations fields -->
                <field name="studynumberrow" type="hidden" default="0"/>
                <field name="studynumbercol" type="hidden" default="1"/>
                <field name="studynumbercolspan" type="hidden" default="0"/>
                <field name="studynumberelement" type="hidden" default="1"/>
                <field name="studynumbercustom" type="hidden" default=""/>
                <field name="studynumberlinktype" type="hidden" default="0"/>
                <field name="topicrow" type="hidden" default="0"/>
                <field name="topiccol" type="hidden" default="1"/>
                <field name="topiccolspan" type="hidden" default="6"/>
                <field name="topicelement" type="hidden" default="1"/>
                <field name="topiccustom" type="hidden" default=""/>
                <field name="topiclinktype" type="hidden" default="0"/>
                <field name="locationsrow" type="hidden" default="0"/>
                <field name="locationscol" type="hidden" default="1"/>
                <field name="locationscolspan" type="hidden" default="0"/>
                <field name="locationselement" type="hidden" default="1"/>
                <field name="locationscustom" type="hidden" default=""/>
                <field name="locationslinktype" type="hidden" default="0"/>
                <!-- Message Type, Thumbnail, Custom fields -->
                <field name="messagetyperow" type="hidden" default="0"/>
                <field name="messagetypecol" type="hidden" default="1"/>
                <field name="messagetypecolspan" type="hidden" default="6"/>
                <field name="messagetypeelement" type="hidden" default="1"/>
                <field name="messagetypecustom" type="hidden" default=""/>
                <field name="messagetypelinktype" type="hidden" default="0"/>
                <field name="thumbnailrow" type="hidden" default="0"/>
                <field name="thumbnailcol" type="hidden" default="1"/>
                <field name="thumbnailcolspan" type="hidden" default="0"/>
                <field name="thumbnailelement" type="hidden" default="1"/>
                <field name="thumbnailcustom" type="hidden" default=""/>
                <field name="thumbnaillinktype" type="hidden" default="0"/>
                <field name="customrow" type="hidden" default="0"/>
                <field name="customcol" type="hidden" default="1"/>
                <field name="customcolspan" type="hidden" default="0"/>
                <field name="customelement" type="hidden" default="1"/>
                <field name="customcustom" type="hidden" default=""/>
                <field name="customtext" type="hidden" default=""/>
            </fieldset>
            <fieldset name="advanced">
                <field
                        name="layout"
                        type="modulelayout"
                        extension="mod_proclaim"
                        class="form-select"
                        label="JFIELD_ALT_LAYOUT_LABEL"
                        description="JFIELD_ALT_MODULE_LAYOUT_DESC"/>

                <field
                        name="cache"
                        type="list"
                        default="1"
                        class="form-select"
                        label="COM_MODULES_FIELD_CACHING_LABEL"
                        description="COM_MODULES_FIELD_CACHING_LABEL">
                    <option
                            value="1">JGLOBAL_USE_GLOBAL
                    </option>
                    <option
                            value="0">COM_MODULES_FIELD_VALUE_NOCACHING
                    </option>
                </field>

                <field
                        name="cache_time"
                        type="text"
                        default="900"
                        label="COM_MODULES_FIELD_CACHE_TIME_LABEL"
                        description="COM_MODULES_FIELD_CACHE_TIME_LABEL"/>
            </fieldset>
        </fields>
    </config>
</extension>
