<?xml version="1.0" encoding="utf-8"?>
<!-- $Id: default.xml tf 12-11-2007 $ -->
<metadata>
    <layout title="JBS_MNU_PODCASTS_LIST_EDIT_LAYOUT">
        <message>
            <![CDATA[JBS_MNU_PODCASTS_LIST_EDIT_LAYOUT_DESC]]>
        </message>
    </layout>
    <fields name="params">
        <fieldset name="basic"
                  label="JBS_MNU_PODCASTS_LIST_LAYOUT"
                  addfieldprefix="CWM\Component\Proclaim\Administrator\Field">

            <field name="mteacher_id"
                   type="TeacherList"
                   label="JBS_CMN_FILTERS_TEACHER"
                   description="JBS_CMN_FILTERS_DESC"
                   multiple="true"
                   default="-1"
            >
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>
            <field name="mseries_id"
                   type="Series"
                   multiple="true"
                   label="JBS_CMN_FILTERS_SERIES"
                   description="JBS_CMN_FILTERS_DESC"
                   default="-1">
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>
            <field name="mbooknumber"
                   type="BookList"
                   class="inputbox"
                   label="JBS_CMN_FILTERS_BOOKS"
                   multiple="true"
                   size="10"
                   translate="true"
                   description="JBS_CMN_FILTERS_DESC"
                   default="-1">
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>
            <field name="mtopic_id" type="TopicsList" default="-1" multiple="true" size="10"
                   label="JBS_CMN_FILTERS_TOPICS"
                   description="JBS_CMN_FILTERS_DESC"
                   class="inputbox">
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>
            <field name="mmessagetype"
                   type="MessageTypeList"
                   multiple="true"
                   label="JBS_CMN_FILTERS_MESSAGETYPES"
                   description="JBS_CMN_FILTERS_DESC"
                   default="-1">
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>
            <field name="mlocations"
                   type="LocationList"
                   multiple="true"
                   label="JBS_CMN_FILTERS_LOCATIONS"
                   description="JBS_CMN_FILTERS_DESC"
                   default="-1">
                <option value="-1">JBS_CMN_SHOW_ALL</option>
            </field>

            <field name="show_archived"
                   type="list"
                   label="JBS_CMN_SHOW_ARCHIVED"
                   description="JBS_CMN_SHOW_ARCHIVED_DESC"
                   default="">
                <option value="">JBS_CMN_USE_TEMPLATE_DEFAULT</option>
                <option value="0">JBS_CMN_PUBLISHED_ONLY</option>
                <option value="1">JBS_CMN_ARCHIVED_ONLY</option>
                <option value="2">JBS_CMN_BOTH_PUBLISHED_ARCHIVED</option>
            </field>

            <field name="show_archive_badge"
                   type="list"
                   label="JBS_CMN_SHOW_ARCHIVE_BADGE"
                   description="JBS_CMN_SHOW_ARCHIVE_BADGE_DESC"
                   default="1">
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>

        </fieldset>

    </fields>
</metadata>
