{
  "name": "joomla-bible-study/proclaim",
  "type": "project",
  "description": "CWM Proclaim",
  "keywords": [
    "bible",
    "joomla",
    "comments",
    "Proclaim"
  ],
  "homepage": "https://github.com/Joomla-Bible-Study/Proclaim",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Tom Fuller",
      "email": "info@christianwebministries.org",
      "homepage": "https://www.christianwebministries.org",
      "role": "Tech Writer & Developer"
    },
    {
      "name": "Brent Cordis",
      "email": "info@christianwebministries.org",
      "homepage": "https://www.christianwebministries.org",
      "role": "Lead Developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.3.0"
    },
    "vendor-dir": "libraries/vendor",
    "github-protocols": [
      "https"
    ],
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "support": {
    "issues": "https://www.christianwebministries.org/issues",
    "forum": "https://www.christianwebministries.org/forum",
    "docs": "https://www.christianwebministries.org/docs"
  },
  "autoload": {
    "psr-12": {
      "CWM\\Component\\Proclaim\\Administrator\\": "admin/src/",
      "CWM\\Component\\Proclaim\\Site\\": "site/src/",
      "CWM\\Proclaim\\Libraries\\": "libraries/src/"
    }
  },
  "autoload-dev": {
    "psr-12": {
      "CWM\\Component\\Proclaim\\Tests\\": "tests/unit/"
    }
  },
  "require": {
    "php": "^8.3.0",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-simplexml": "*",
    "ext-gd": "*",
    "simplepie/simplepie": "^1.8",
    "google/recaptcha": "^1.3",
    "typo3/phar-stream-wrapper": "^3.1.7",
    "jfcherng/php-diff": "^6.16",
    "psr/log": "^3.0",
    "composer/ca-bundle": "^1.3",
    "ext-zip": "*",
    "ext-libxml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "squizlabs/php_codesniffer": "^4.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2",
    "phan/phan": "^5.4",
    "roave/security-advisories": "dev-latest",
    "phing/phing": "^3.0",
    "pdepend/pdepend": "^2.16",
    "phpmd/phpmd": "^2.15"
  },
  "replace": {
    "paragonie/random_compat": "9.99.99",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "2.x-dev"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --dry-run --diff",
    "lint:fix": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix",
    "cs": "phpcs . --standard=./build/psr12/ruleset.xml",
    "check": ["@lint", "@test"],
    "build:assets": "npm install && npm run build",
    "setup": "libraries/vendor/bin/phing dev.setup",
    "joomla-install": "libraries/vendor/bin/phing joomla.install",
    "joomla-latest": "libraries/vendor/bin/phing joomla.get-latest-version",
    "symlink": "libraries/vendor/bin/phing dev.Setup_Symbolic_Links",
    "sync-languages": "libraries/vendor/bin/phing sync-languages",
    "sync-languages-setup": "libraries/vendor/bin/phing sync-languages-setup",
    "post-install-cmd": [
      "\"libraries/vendor/bin/phpcs\" --config-set installed_paths libraries/vendor/squizlabs/php_codesniffer/src/Standards",
      "@php -r \"if (!file_exists('build.properties')) { copy('build.dist.properties', 'build.properties'); echo 'Created build.properties from template. Run composer setup to configure.\\n'; }\""
    ],
    "post-update-cmd": "\"libraries/vendor/bin/phpcs\" --config-set installed_paths libraries/vendor/squizlabs/php_codesniffer/src/Standards"
  }
}
