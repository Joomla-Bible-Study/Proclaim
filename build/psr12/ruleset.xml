<?xml version="1.0"?>
<ruleset name="CWM-Proclaim">
    <description>The CWM Proclaim exceptions.</description>

    <!-- Exclude folders not containing production code -->
    <exclude-pattern>.*/admin/cache/.*</exclude-pattern>
    <exclude-pattern>.*/admin/logs/.*</exclude-pattern>
    <exclude-pattern>.*/admin/helpers/.*</exclude-pattern>
    <exclude-pattern>.*/build/.*</exclude-pattern>
    <exclude-pattern>.*/cache/.*</exclude-pattern>
    <exclude-pattern>.*/media/.*</exclude-pattern>
    <exclude-pattern>.*/node_modules/.*</exclude-pattern>
    <exclude-pattern>.*/tmp/.*</exclude-pattern>
    <exclude-pattern>.*/\.idea/.*</exclude-pattern>
    <exclude-pattern>.*/tests/unit/.*</exclude-pattern>
    <exclude-pattern>.*/tmpl/.*</exclude-pattern>

    <!-- will need ot look at removing them as will move to namespace soon -->
    <exclude-pattern>.*/plugins/system/proclaimbackup/script\.php</exclude-pattern>
    <exclude-pattern>.*/plugins/system/proclaimbackup/proclaimbackup\.php</exclude-pattern>
    <exclude-pattern>.*/plugins/system/proclaimpodcast/script\.php</exclude-pattern>

    <!-- Install script -->
    <exclude-pattern>.*/proclaim\.script\.php</exclude-pattern>

    <!-- Exclude 3rd party libraries and Framework code. -->
    <exclude-pattern>.*/libraries/php-encryption/.*</exclude-pattern>
    <exclude-pattern>.*/libraries/phpass/.*</exclude-pattern>
    <exclude-pattern>.*/vendor/.*</exclude-pattern>

    <rule ref="PSR12" />

    <!-- temporary extend the line length -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="560"/>
            <property name="absoluteLineLimit" value="560"/>
        </properties>
    </rule>

    <rule ref="PSR2.Methods.MethodDeclaration.Underscore">
        <exclude-pattern>.*/admin/src/Table/.*</exclude-pattern>
        <exclude-pattern>.*/tests/.*</exclude-pattern>
    </rule>

    <rule ref="PSR1.Methods.CamelCapsMethodName.NotCamelCaps">
    </rule>

    <rule ref="PSR2.Methods.MethodDeclaration.Underscore">
        <exclude-pattern>.*/site/src/Model/CwmlandingpageModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmpodcastdisplayModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmpodcastlistModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmpopupModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmseriesdisplayModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmseriesdisplaysModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmsermonModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmsermonsModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmserverslistModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmteacherModel\.php</exclude-pattern>
        <exclude-pattern>.*/site/src/Model/CwmteachersModel\.php</exclude-pattern>
    </rule>
    
    <rule ref="PSR1.Classes.ClassDeclaration.MultipleClasses">
    </rule>

    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
    </rule>
</ruleset>
