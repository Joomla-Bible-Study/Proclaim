<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fields name="schema">
        <fieldset name="schema" label="PLG_SCHEMAORG_PROCLAIM_SCHEMA_LABEL">

            <!-- JSON of auto-generated field values for edit detection -->
            <field name="_autoValues" type="hidden" default="{}"/>

            <!-- Sermon schema fields (CreativeWork) -->
            <field name="Sermon" type="subform" showon="schemaType:Sermon">
                <form>
                    <field name="@type" type="hidden" default="CreativeWork"/>

                    <field name="noteSermon" type="note"
                           description="PLG_SCHEMAORG_PROCLAIM_NOTE_SERMON_DESC"
                           class="alert alert-info w-100"/>

                    <field name="image" type="media"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_IMAGE"/>

                    <field name="headline" type="text"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_HEADLINE"
                           filter="string" size="60"/>

                    <field name="description" type="textarea"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_DESCRIPTION"
                           filter="string" rows="3"/>

                    <field name="author" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_AUTHOR">
                        <form>
                            <field name="@type" type="hidden" default="Person"/>
                            <field name="name" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_AUTHOR_NAME"
                                   filter="string"/>
                        </form>
                    </field>

                    <field name="datePublished" type="calendar"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_DATE_PUBLISHED"
                           class="input-small" filter="user_utc"
                           showtime="false" todaybutton="true"
                           translateformat="true"/>

                    <field name="dateModified" type="calendar"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_DATE_MODIFIED"
                           class="input-small" filter="user_utc"
                           showtime="false" todaybutton="true"
                           translateformat="true"/>

                    <field name="genericField" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM"
                           multiple="true">
                        <form>
                            <field name="genericTitle" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_KEY"
                                   filter="string" size="30"/>
                            <field name="genericValue" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_VALUE"
                                   filter="string" size="30"/>
                        </form>
                    </field>

                </form>
            </field>

            <!-- Teacher schema fields (Person) -->
            <field name="Teacher" type="subform" showon="schemaType:Teacher">
                <form>
                    <field name="@type" type="hidden" default="Person"/>

                    <field name="noteTeacher" type="note"
                           description="PLG_SCHEMAORG_PROCLAIM_NOTE_TEACHER_DESC"
                           class="alert alert-info w-100"/>

                    <field name="image" type="media"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_IMAGE"/>

                    <field name="name" type="text"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_NAME"
                           filter="string" size="60"/>

                    <field name="jobTitle" type="text"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_JOB_TITLE"
                           filter="string" size="60"/>

                    <field name="description" type="textarea"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_DESCRIPTION"
                           filter="string" rows="3"/>

                    <field name="url" type="url"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_URL"
                           filter="url" validate="url"/>

                    <field name="sameAs" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_SAME_AS"
                           multiple="true">
                        <form>
                            <field name="value" type="url"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_SOCIAL_URL"
                                   filter="url" validate="url" size="60"/>
                        </form>
                    </field>

                    <field name="worksFor" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_WORKS_FOR">
                        <form>
                            <field name="@type" type="hidden" default="Organization"/>
                            <field name="name" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_ORG_NAME"
                                   filter="string" size="60"/>
                        </form>
                    </field>

                    <field name="genericField" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM"
                           multiple="true">
                        <form>
                            <field name="genericTitle" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_KEY"
                                   filter="string" size="30"/>
                            <field name="genericValue" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_VALUE"
                                   filter="string" size="30"/>
                        </form>
                    </field>

                </form>
            </field>

            <!-- Series schema fields (CreativeWorkSeries) -->
            <field name="Series" type="subform" showon="schemaType:Series">
                <form>
                    <field name="@type" type="hidden" default="CreativeWorkSeries"/>

                    <field name="noteSeries" type="note"
                           description="PLG_SCHEMAORG_PROCLAIM_NOTE_SERIES_DESC"
                           class="alert alert-info w-100"/>

                    <field name="image" type="media"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_IMAGE"/>

                    <field name="name" type="text"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_NAME"
                           filter="string" size="60"/>

                    <field name="description" type="textarea"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_DESCRIPTION"
                           filter="string" rows="3"/>

                    <field name="genericField" type="subform"
                           label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM"
                           multiple="true">
                        <form>
                            <field name="genericTitle" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_KEY"
                                   filter="string" size="30"/>
                            <field name="genericValue" type="text"
                                   label="PLG_SCHEMAORG_PROCLAIM_FIELD_CUSTOM_VALUE"
                                   filter="string" size="30"/>
                        </form>
                    </field>

                </form>
            </field>

        </fieldset>
    </fields>
</form>
