  "browserslist": [
    "last 2 major versions",
    "not IE < 11"
  ],
  "dependencies": {
    "core-js": "^3.38.1",
    "@hapi/cryptiles": "^6.0.1",
    "@hapi/hoek": "^11.0.4",
    "csso": "^5.0.5",
    "less": "^4.2.0"
  }
