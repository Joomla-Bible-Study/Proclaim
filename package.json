{
  "name": "cwmproclaim",
  "version": "1.0.0",
  "description": "CWM Proclaim - A Joomla! Extension for Church Media Management",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joomla-Bible-Study/Proclaim.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.2",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.2",
    "terser": "^5.27.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "useBuiltIns": "entry",
          "corejs": {
            "version": "3.38",
            "proposals": true
          }
        }
      ]
    ],
    "comments": false,
    "ignore": []
