{
  "name": "com_proclaim",
  "version": "10.2.0",
  "description": "CWM Proclaim - A Joomla! Extension for Church Media Management",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joomla-Bible-Study/Proclaim.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^30.0.0",
    "csso": "^5.0.5",
    "eslint": "^10.0.1",
    "globals": "^15.14.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "rollup": "^4.58.0",
    "rollup-plugin-gzip": "^4.1.1",
    "sortablejs": "^1.15.7",
    "terser": "^5.46.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "useBuiltIns": "entry",
          "corejs": {
            "version": "3.48",
            "proposals": true
          }
        }
      ]
    ],
    "comments": false,
    "ignore": []
  },
  "browserslist": [
    "last 2 major versions"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css && npm run build:assets",
    "build:js": "rollup -c build/rollup.config.js",
    "build:css": "node build/build-css.js",
    "build:assets": "node build/build-assets.js",
    "watch": "rollup -c build/rollup.config.js -w",
    "test": "node --no-deprecation node_modules/.bin/jest -c build/jest.config.js",
    "test:watch": "node --no-deprecation node_modules/.bin/jest -c build/jest.config.js --watch",
    "test:coverage": "node --no-deprecation node_modules/.bin/jest -c build/jest.config.js --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report build/reports/e2e",
    "lint:js": "eslint --max-warnings=0 ."
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.11",
    "chart.js": "^4.5.1",
    "core-js": "^3.48.0",
    "intl-tel-input": "^26.5.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}