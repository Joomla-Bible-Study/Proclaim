{
  "name": "cwmproclaim",
  "version": "1.0.0",
  "description": "CWM Proclaim - A Joomla! Extension for Church Media Management",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Joomla-Bible-Study/Proclaim.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.1.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^29.5.14",
    "csso": "^5.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^4.57.0",
    "terser": "^5.46.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "useBuiltIns": "entry",
          "corejs": {
            "version": "3.38",
            "proposals": true
          }
        }
      ]
    ],
    "comments": false,
    "ignore": []
  },
  "browserslist": [
    "last 2 major versions",
    "not IE < 11"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "rollup -c build/rollup.config.js",
    "build:css": "node build/build-css.js",
    "watch": "rollup -c build/rollup.config.js -w",
    "test": "jest -c build/jest.config.js",
    "test:watch": "jest -c build/jest.config.js --watch",
    "test:coverage": "jest -c build/jest.config.js --coverage"
  },
  "dependencies": {
    "@hapi/cryptiles": "^6.0.3",
    "@hapi/hoek": "^11.0.7",
    "core-js": "^3.48.0"
  }
}
