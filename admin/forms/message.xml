<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details" addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
        <field name="id" type="text" label="JGLOBAL_FIELD_ID_LABEL"
               description="JGLOBAL_FIELD_ID_DESC" size="10" default="0"
               readonly="true"/>

        <field name="published"
               type="status"
               label="JSTATUS"
               description="JFIELD_PUBLISHED_DESC"
               default="1"
               filter="int"/>

        <field name="server" type="ServerList" label="JBS_CMN_SERVER"
               description="JBS_MED_SERVER_DESC" default="-1">
            <option value="-1">JBS_CMN_SELECT_SERVER</option>
        </field>

        <field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL"
               description="JBS_CMN_SELECT_LANGUAGE_DESC">
            <option value="*">JALL</option>
        </field>

        <field name="download_id" type="MediaFile" label="JBS_STY_DOWNLOAD_LINK"
               description="JBS_STY_DOWNLOAD_LINK_DESC" default="0">
            <option value="-1">JBS_STY_SELECT_DOWNLOAD_LINK</option>
        </field>

        <field name="studydate" type="cwmcalendar" label="JBS_CMN_STUDY_DATE"
               description="JBS_STY_CREATE_DATE_DESC" translateformat="true"
               showtime="true" timeformat="12" filter="user_utc" required="true"/>

        <field name="comments" type="list" label="JBS_CMN_COMMENTS"
               description="JBS_STY_COMMENTS_DESC"
               default="0">
            <option value="0">JBS_CMN_NO</option>
            <option value="1">JBS_CMN_YES</option>
        </field>

        <field name="user_id" type="user" label="JBS_CMN_SUBMITTED_BY"/>

        <field name="studytitle" type="text" size="60" label="JBS_CMN_TITLE" required="true"
               filter="trim"/>

        <field name="alias"
               type="text"
               label="JFIELD_ALIAS_LABEL"
               description="JFIELD_ALIAS_DESC"
               size="30"
        />

        <field name="studyintro" type="editor" label="JBS_CMN_DESCRIPTION"
               filter="CWM\Component\Proclaim\Administrator\Helper\CwmproclaimHelper::filterText" buttons="true"/>
        <field name="studytext" type="editor" label="JBS_STY_STUDY_TEXT"
               filter="CWM\Component\Proclaim\Administrator\Helper\CwmproclaimHelper::filterText" buttons="true"/>

        <field name="studynumber" type="text" size="15" label="JBS_CMN_STUDYNUMBER"/>

        <fieldset name="scripture" label="JBS_CMN_SCRIPTURE">
            <field name="scriptures" type="subform"
                   label="JBS_CMN_SCRIPTURE_REFERENCES"
                   description="JBS_CMN_SCRIPTURE_REFERENCES_DESC"
                   formsource="scripture_row"
                   multiple="true"
                   min="0" max="20"
                   groupByFieldset="false"
                   layout="joomla.form.field.subform.repeatable-table"
                   buttons="add,remove,move"/>
            <field name="secondary_reference" type="text" size="100"
                   label="JBS_CMN_SECONDARY_REFERENCES"
                   description="JBS_STY_SECONDARY_REFERENCES_DESC"
                   filter="trim"/>
        </fieldset>

        <field name="teacher_id" type="hidden" default="0"/>

        <field name="teachers" type="subform"
               label="JBS_CMN_TEACHERS"
               description="JBS_CMN_TEACHERS_DESC"
               formsource="teacher_row"
               multiple="true"
               min="0" max="10"
               groupByFieldset="false"
               layout="joomla.form.field.subform.repeatable-table"
               buttons="add,remove,move"/>

        <field name="location_id" type="LocationList" label="JBS_CMN_LOCATION"
               description="JBS_FLD_LOCATION_DESC">
            <option value="-1">JBS_CMN_SELECT_LOCATION</option>
        </field>

        <field name="series_id" type="Modal_Series" label="JBS_CMN_SERIES"
               select="true" new="true" edit="true" clear="true"/>

        <field name="topics" type="TopicsForm" label="JBS_CMN_TOPIC_TAG"
               description="JBS_CMN_TOPIC_TAG_DESC" multiple="true"/>

        <field name="messagetype" type="MessageTypeList" label="JBS_CMN_MESSAGETYPE"
               description="JBS_STY_MESSAGETYPE_DESC">
            <option value="-1">JBS_CMN_SELECT_MESSAGETYPE</option>
        </field>

        <field name="thumbnailm" type="hidden"/>
        <field name="image" type="media" directory="biblestudy/studies" label="JBS_STY_STUDY_IMAGE"/>

        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               translate_label="false" filter="rules" component="com_proclaim"
               section="message" validate="rules"/>

        <field
                name="created"
                type="calendar"
                label="JGLOBAL_FIELD_CREATED_LABEL"
                translateformat="true"
                showtime="true"
                filter="user_utc"
        />
        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                validate="UserId"
        />
        <field
                name="created_by_alias"
                type="text"
                label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
        />
        <field
                name="modified"
                type="calendar"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
                class="form-control"
                translateformat="true"
                showtime="true"
                readonly="true"
                filter="user_utc"
        />

        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                class="readonly"
                readonly="true"
                filter="unset"
                validate="UserId"
        />

        <field name="checked_out" type="hidden" filter="unset"/>

        <field name="checked_out_time" type="hidden" filter="unset"/>

        <field name="publish_up"
               type="calendar"
               label="JGLOBAL_FIELD_PUBLISH_UP_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"
        />

        <field name="publish_down"
               type="calendar"
               label="JGLOBAL_FIELD_PUBLISH_DOWN_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"
        />

        <field name="access" type="accesslevel" label="JFIELD_ACCESS_LABEL"
               description="JBS_FLD_ACCESS_VS_LOCATION_DESC"/>
        <field name="asset_id" type="hidden" filter="unset"/>
    </fieldset>

    <fields name="params">
        <fieldset name="params">
            <field name="nooverlaysimplemode" type="list" label="CWM_SIMPLE_MODE_TEXT_OVERLAY"
                   description="CWM_SIMPLE_MODE_TEXT_OVERLAY_DESC"
                   default="yes">
                <option value="no">JBS_CMN_NO</option>
                <option value="yes">JBS_CMN_YES</option>
            </field>
            <field name="metakey" type="textarea" label="JBS_STY_METAKEYWORDS"
                   description="JBS_STY_METAKEYWORDS_DESC" rows="3" size="30" filter="string"/>
            <field name="metadesc" type="textarea" label="JBS_STY_METADESCRIPTION"
                   description="JBS_STY_METADESCRIPTION_DESC" cols="30" rows="3" filter="string"/>
        </fieldset>
    </fields>
</form>
