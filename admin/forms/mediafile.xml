<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details" addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
        <field
                name="id"
                type="text"
                default="0"
                readonly="true"
                label="JGLOBAL_FIELD_ID_LABEL"
                description="JGLOBAL_FIELD_ID_DESC"
        />

        <field
                name="published"
                type="status"
                label="JSTATUS"
                description="JFIELD_PUBLISHED_DESC"
                default="1"
                filter="int"/>

        <field name="createdate" type="calendar" label="JBS_CMN_CREATE_DATE"
               description="JBS_MED_CREATE_DATE_DESC"
               translateformat="true"
               showtime="true"
               filter="user_utc"/>

        <field name="study_id" type="Modal_Study" label="JBS_CMN_STUDY"
               description="JBS_MED_CHOOSE_STUDY_DESC" required="true"/>

        <field name="comment" type="textarea" rows="4" label="JBS_CMN_COMMENT"
               description="JBS_MED_APPEARS_UNDER_FILE_OR_TOOLTIP"/>

        <field name="server_id" type="Server" label="JBS_CMN_SERVER"
               description="JBS_MED_SERVER_DESC" required="true"/>

        <field name="podcast_id" type="Podcasts" label="JBS_MED_CHOOSE_PODCAST"
               description="JBS_MED_CHOOSE_PODCAST_DESC" multiple="true" default="">
        </field>

        <field name="language"
               type="contentlanguage"
               label="JFIELD_LANGUAGE_LABEL">
            <option value="*">JALL</option>
        </field>

        <field name="metadata" type="hidden" filter="unset"/>
        <field name="asset_id" type="hidden" filter="unset"/>

        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               translate_label="false" filter="rules" component="com_proclaim"
               section="mediafile" validate="rules"/>

        <field name="access" type="accesslevel" label="JFIELD_ACCESS_LABEL"
               description="JFIELD_ACCESS_DESC"
               filter="UINT"
               validate="options"
        />

        <field name="created" type="calendar"
               label="JGLOBAL_FIELD_CREATED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>

        <field name="created_by" type="user"
               label="JGLOBAL_FIELD_CREATED_BY_LABEL"
               readonly="true"
               filter="unset"/>

        <field name="created_by_alias" type="text"
               label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
               size="20" filter="string"/>

        <field name="modified" type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>

        <field name="modified_by" type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               readonly="true"
               filter="unset"/>

        <!--Server-media-specific fields-->
        <field name="params"/>
    </fieldset>
</form>
