<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
        <field name="published"
               type="status"
               label="JSTATUS"
               description="JFIELD_PUBLISHED_DESC"
               default="1"
               filter="int"/>
        <field
                name="series_text"
                type="text"
                label="JBS_SER_SERIES_NAME"
                required="true"
                maxlenght="255"
                filter="trim"
        />

        <field name="alias" type="text" label="JFIELD_ALIAS_LABEL"
               description="JFIELD_ALIAS_DESC" size="45"/>

        <field name="landing_show" default="1" type="list" label="JBS_CMN_LANDING_SHOW"
               description="JBS_CMN_LANDING_SHOW_DESC">
            <option value="0">JBS_CMN_NO_SHOW_LANDING</option>
            <option value="1">JBS_CMN_SHOW_ABOVE_LANDING</option>
            <option value="2">JBS_CMN_SHOW_BELOW_LANDING</option>
        </field>
        <field name="pc_show" type="radio" layout="joomla.form.field.radio.switcher" default="0"
               label="JBS_ADM_SERIE_PC_SHOW" description="JBS_ADM_SERIE_PC_SHOW_DESC">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field name="teacher" type="TeacherList" label="JBS_CMN_TEACHER">
            <option value="-1">JBS_CMN_SELECT_TEACHER</option>
        </field>
        <field name="buttonspacer"
               description="JGLOBAL_ACTION_PERMISSIONS_DESCRIPTION"
               type="spacer"/>
        <field name="description" type="editor"
               label="JBS_CMN_DESCRIPTION" filter="CWM\Component\Proclaim\Administrator\Helper\CwmproclaimHelper::filterText"
               buttons="true"/>
        <field name="series_thumbnail" type="hidden"/>
        <field name="image" type="media" directory="biblestudy" label="JBS_CMN_SERIES_THUMBNAIL"/>
        <field name="location_id" type="LocationList" label="JBS_CMN_LOCATION"
               description="JBS_FLD_LOCATION_DESC">
            <option value="-1">JBS_CMN_SELECT_LOCATION</option>
        </field>
        <field name="access" type="accesslevel" label="JFIELD_ACCESS_LABEL"
               description="JBS_FLD_ACCESS_VS_LOCATION_DESC" class="col-12 small" size="1"/>
        <field name="asset_id" type="hidden" filter="unset"/>
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               translate_label="false" filter="rules" component="com_proclaim"
               section="serie" validate="rules"/>
        <field name="id" type="hidden" default="0"/>
        <field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL"
               description="COM_CONTENT_FIELD_LANGUAGE_DESC" class="col-12 small"
        >
            <option value="*">JALL</option>
        </field>
        <field name="ordering" type="text" label="JBS_CMN_ORDERING"
               description="JBS_CMN_ORDERING_DESC" size="5" default="0"/>

        <field name="created" type="calendar"
               label="JGLOBAL_FIELD_CREATED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="created_by" type="user"
               label="JGLOBAL_FIELD_CREATED_BY_LABEL"
               readonly="true"
               filter="unset"/>
        <field name="created_by_alias" type="text"
               label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
               size="20" filter="string"/>

        <field name="modified" type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="modified_by" type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               readonly="true"
               filter="unset"/>

        <field name="publish_up"
               type="calendar"
               label="JGLOBAL_FIELD_PUBLISH_UP_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"
        />
        <field name="publish_down"
               type="calendar"
               label="JGLOBAL_FIELD_PUBLISH_DOWN_LABEL"
               translateformat="true"
               showtime="true"
               filter="user_utc"
        />
    </fieldset>
</form>
