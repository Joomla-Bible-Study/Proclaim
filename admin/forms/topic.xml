<?xml version="1.0" encoding="utf-8"?>
<form>
    <field name="topic_text" type="text" label="JBS_TPC_TOPIC_ALIAS" description="JBS_TPC_TOPIC_ALIAS_DESC"
           size="75" filter="trim"/>
    <field name="published"
           type="status"
           label="JSTATUS"
           description="JFIELD_PUBLISHED_DESC"
           default="1"
           filter="int"/>
    <field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL"
           description="com_proclaim_LANGUAGE_DESC">
        <option value="*">JALL</option>
    </field>
    <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL" translate_label="false"
           filter="rules"
           component="com_proclaim" section="topic" validate="rules"/>
    <field name="asset_id" type="hidden" filter="unset"/>
    <field name="id" type="text" label="JGLOBAL_FIELD_ID_LABEL"
           description="JGLOBAL_FIELD_ID_DESC" size="10" default="0" readonly="true"/>

    <field
            name="created"
            type="calendar"
            label="JGLOBAL_FIELD_CREATED_LABEL"
            translateformat="true"
            showtime="true"
            filter="user_utc"
    />
    <field
            name="created_by"
            type="user"
            label="JGLOBAL_FIELD_CREATED_BY_LABEL"
            validate="UserId"
    />
    <field
            name="created_by_alias"
            type="text"
            label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
    />
    <field
            name="modified"
            type="calendar"
            label="JGLOBAL_FIELD_MODIFIED_LABEL"
            class="form-control"
            translateformat="true"
            showtime="true"
            readonly="true"
            filter="user_utc"
    />

    <field
            name="modified_by"
            type="user"
            label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
            class="readonly"
            readonly="true"
            filter="unset"
            validate="UserId"
    />
</form>
