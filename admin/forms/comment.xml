<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
        <field name="published"
               type="status"
               label="JSTATUS"
               description="JFIELD_PUBLISHED_DESC"
               default="1"
               filter="int"/>
        <field name="language" type="contentlanguage" label="JFIELD_LANGUAGE_LABEL"
               description="JBS_CMN_SELECT_LANGUAGE_DESC" class="col-12">
            <option value="*">JALL</option>
        </field>
        <field name="study_id" type="Modal_Study" label="JBS_CMN_STUDY"
               description="JBS_CMT_CHOOSE_STUDY_DESC" required="true"/>
        <field name="comment_date" type="calendar" label="JBS_CMT_CREATE_DATE"
               description="JBS_CMT_CREATE_DATE_DESC" translateformat="true"
               showtime="true" filter="user_utc" required="true"/>
        <field name="full_name" type="text" label="JBS_CMT_FULL_NAME"
               size="30"/>
        <field name="user_email" type="email" label="JBS_CMT_EMAIL" size="40"
               validate="email"/>
        <field name="comment_text" type="editor" label="JBS_CMN_COMMENT"
               rows="10" cols="50" filter="CWM\Component\Proclaim\Administrator\Helper\CwmproclaimHelper::filterText" buttons="true"/>
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               translate_label="false" filter="rules" component="com_proclaim"
               section="comment" validate="rules"/>
        <field name="asset_id" type="hidden" filter="unset"/>
        <field name="id" type="text" class="col-12" label="JGLOBAL_FIELD_ID_LABEL"
               description="JGLOBAL_FIELD_ID_DESC" size="10" default="0"
               readonly="true"/>
    </fieldset>
</form>
