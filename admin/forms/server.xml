<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset addfieldprefix="CWM\Component\Proclaim\Administrator\Field">
        <field name="id" type="text" label="JGLOBAL_FIELD_ID_LABEL"
               description="JGLOBAL_FIELD_ID_DESC" size="10" default="0"
               readonly="true"/>
        <field name="published"
               type="status"
               label="JSTATUS"
               description="JFIELD_PUBLISHED_DESC"
               default="1"
               filter="int"/>
        <field name="type"
               type="Modal_ServerType"
               label="JBS_CMN_SERVER"
               description="JBS_MED_SERVER_DESC"
               required="true"/>
        <field name="server_name" type="text" label="JBS_SVR_SERVER_NAME"
               description="JBS_SVR_SERVER_NAME_DESC" size="50" required="true"/>
        <field name="rules" type="rules" label="JCONFIG_PERMISSIONS_LABEL"
               translate_label="false" filter="rules" component="com_proclaim"
               section="server" validate="rules"/>
        <field name="asset_id" type="hidden" filter="unset"/>

        <field name="created" type="calendar"
               label="JGLOBAL_FIELD_CREATED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="created_by" type="user"
               label="JGLOBAL_FIELD_CREATED_BY_LABEL"
               readonly="true"
               filter="unset"/>
        <field name="created_by_alias" type="text"
               label="JGLOBAL_FIELD_CREATED_BY_ALIAS_LABEL"
               size="20"/>

        <field name="modified" type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               readonly="true" translateformat="true"
               showtime="true"
               filter="user_utc"/>
        <field name="modified_by" type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               readonly="true"
               filter="unset"/>
    </fieldset>

    <!-- Server specific fields-->
    <field name="params"/>
    <field name="media"/>
</form>
