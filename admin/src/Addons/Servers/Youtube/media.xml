<?xml version="1.0" encoding="utf-8"?>
<media>
    <fields name="params">
        <fieldset name="general" addfieldprefix="CWM\Component\Proclaim\Administrator\Addons\Servers\Youtube\Field">
            <field name="filename"
                   type="text"
                   label="JBS_ADDON_YOUTUBE_URL"
                   description="JBS_ADDON_YOUTUBE_URL_DISC"
                   class="inputbox"
                   required="true"/>
            <field name="youtube_browse_btn"
                   type="YoutubeBrowseBtn"
                   class="youtube-browse-container"
                   label=""
                   description=""/>
            <field name="popup" type="list" label="JBS_MED_INTERNAL_POPUP"
                   description="JBS_MED_INTERNAL_POPUP_DESC"
                   class="form-select-color-state"
                   size="1"
                   default=""
                   validate="options">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="1">JBS_CMN_POPUP</option>
                <option value="2">JBS_CMN_INLINE</option>
                <option value="3">JBS_CMN_SQUEEZEBOX</option>
            </field>
        </fieldset>
        <fieldset name="details" label="JBS_ADDON_YOUTUBE_DETAILS">
            <field name="media_image" type="media" directory="biblestudy"
                   label="JBS_CMN_IMAGE" description="JBS_MED_IMAGE_DESC"
                   class="inputbox">
            </field>
            <field name="media_use_button_icon" type="list"
                   class="form-select-color-state"
                   size="1"
                   default=""
                   validate="options"
                   label="JBS_ADDON_YOUTUBE_MEDIA_USE_BUTTON"
                   description="JBS_ADDON_YOUTUBE_MEDIA_USE_BUTTON_DESC">
                <option value="-1">JBS_MED_SERVER_OPTIONS</option>
                <option value="">JBS_MED_NONE</option>
                <option value="1">JBS_MED_BUTTON_ONLY</option>
                <option value="2">JBS_MED_BUTTON_AND_ICON</option>
                <option value="3">JBS_MED_ICON_ONLY</option>
            </field>
            <field name="media_button_text" type="text" default="YouTube" label="JBS_ADDON_YOUTUBE_BUTTON_TEXT"
                   description="JBS_ADDON_YOUTUBE_BUTTON_TEXT_DESC"/>
            <field name="media_button_type" type="list"
                   class="form-select-color-state"
                   size="1"
                   default=""
                   validate="options"
                   label="JBS_ADDON_YOUTUBE_BUTTON_TYPE"
                   description="JBS_ADDON_YOUTUBE_BUTTON_TYPE_DESC">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="btn-link">JBS_MED_NO_COLOR</option>
                <option value="btn-primary">JBS_MED_PRIMARY</option>
                <option value="btn-success">JBS_MED_SUCCESS</option>
                <option value="btn-info">JBS_MED_INFO</option>
                <option value="btn-warning">JBS_MED_WARNING</option>
                <option value="btn-danger">JBS_MED_DANGER</option>
            </field>
            <field name="media_button_color" type="ColorPicker" default="black"
                   description="JBS_ADDON_YOUTUBE_BUTTON_COLOR_DESC" label="JBS_ADDON_YOUTUBE_BUTTON_COLOR"/>
            <field name="media_icon_type" type="IconType" class="form-select-color-state" size="1"
                   default="fa-brands fa-youtube"
                   label="JBS_ADDON_YOUTUBE_ICON_TYPE"
                   description="JBS_ADDON_YOUTUBE_ICON_TYPE_DESC">
            </field>
            <field name="media_custom_icon" type="text" default="" label="JBS_ADDON_YOUTUBE_CUSTOM_ICON"
                   description="JBS_ADDON_YOUTUBE_CUSTOM_ICON_DESC"/>
            <field name="link_type" type="hidden" extension="com_proclaim"
                   label="JBS_MED_SHOW_DOWNLOAD_ICON" description="JBS_MED_SHOW_DOWNLOAD_ICON_DESC"
                   class="inputbox" readonly="readonly" size="1" default="0">
                <option value="0">JBS_MED_NO_DOWNLOAD_ICON</option>
            </field>
            <field name="player" type="hidden" label="JBS_MED_PLAYER"
                   description="JBS_MED_PLAYER_DESC" class="inputbox" size="1" default="">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="1">JBS_CMN_USE_INTERNAL_PLAYER</option>
            </field>
        </fieldset>
        <fieldset name="parameters" label="JBS_ADDON_YOUTUBE_PARAMETERS">
            <field name="playerwidth" default="" type="text" label="JBS_MED_PLAYERWIDTH"
                   description="JBS_MED_PLAYERWIDTH_DESC"/>
            <field name="playerheight" default="" type="text"
                   label="JBS_MED_PLAYERHIGHT" description="JBS_MED_PLAYERHIGHT_DESC"/>
            <field name="itempopuptitle" type="textarea" cols="54" rows="10" default="" filter="raw"
                   label="JBS_MED_MEDIA_POPUPTITLE" description="JBS_MED_MEDIA_POPUPTITLE_FOOTER_DESC"/>
            <field name="itempopupfooter" type="textarea" cols="54" rows="10" default="" filter="raw"
                   label="JBS_MED_MEDIA_POPUPFOOTER" description="JBS_MED_MEDIA_POPUPTITLE_FOOTER_DESC"/>
            <field name="popupmargin" type="text" default="50"
                   label="JBS_MED_MEDIA_POPUPMARGIN" description="JBS_MED_MEDIA_POPUPMARGIN_DESC"/>
            <field name="autostart" type="list"
                   label="JBS_CMN_MEDIA_AUTOSTART" description="JBS_CMN_MEDIA_AUTOSTART_DESC" default="">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="true">JYES</option>
                <option value="false">JNO</option>
            </field>
        </fieldset>
        <fieldset name="embed_options" label="JBS_ADDON_YOUTUBE_EMBED_OPTIONS">
            <field name="yt_mute" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_MUTE" description="JBS_ADDON_YOUTUBE_MUTE_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
            <field name="yt_start" type="text" default=""
                   label="JBS_ADDON_YOUTUBE_START" description="JBS_ADDON_YOUTUBE_START_DESC"
                   hint="e.g. 30"/>
            <field name="yt_end" type="text" default=""
                   label="JBS_ADDON_YOUTUBE_END" description="JBS_ADDON_YOUTUBE_END_DESC"
                   hint="e.g. 120"/>
            <field name="yt_loop" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_LOOP" description="JBS_ADDON_YOUTUBE_LOOP_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
            <field name="yt_controls" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_CONTROLS" description="JBS_ADDON_YOUTUBE_CONTROLS_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JHIDE</option>
                <option value="1">JSHOW</option>
            </field>
            <field name="yt_rel" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_REL" description="JBS_ADDON_YOUTUBE_REL_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
            <field name="yt_cc" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_CC" description="JBS_ADDON_YOUTUBE_CC_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
            <field name="yt_playsinline" type="list" default=""
                   label="JBS_ADDON_YOUTUBE_PLAYSINLINE" description="JBS_ADDON_YOUTUBE_PLAYSINLINE_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="0">JNO</option>
                <option value="1">JYES</option>
            </field>
        </fieldset>
    </fields>
</media>
