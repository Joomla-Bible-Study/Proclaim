<?xml version="1.0" encoding="utf-8"?>
<server type="storage" supports="*.*">
    <name>Direct Link</name>
    <description>URL-based direct links without platform API configuration.</description>
    <config>
        <media_resource>filename</media_resource>
    </config>
    <fields name="params">
        <fieldset name="server_settings" label="JBS_ADDON_DIRECT_DETAILS">
            <field name="path" type="text" label="JBS_MED_PATH" description="JBS_MED_PATH_DESC"
                   size="35"/>
            <field name="protocol" type="list" label="JBS_ADDON_DIRECT_PROTOCOL"
                   description="JBS_ADDON_DIRECT_PROTOCOL_DESC" default="">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="http://">http://</option>
                <option value="https://">https://</option>
            </field>
            <field name="link_type" type="hidden" default="0"/>
            <field name="player" type="hidden" default="0"/>
            <field name="popup" type="list" label="JBS_MED_INTERNAL_POPUP"
                   description="JBS_MED_INTERNAL_POPUP_DESC"
                   default="_blank">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="1">JBS_CMN_POPUP</option>
                <option value="2">JBS_CMN_INLINE</option>
                <option value="3">JBS_CMN_SQUEEZEBOX</option>
            </field>
        </fieldset>
    </fields>
    <fields name="media">
        <fieldset name="details" label="JBS_ADDON_DIRECT_MEDIA_TYPE_DEF">
            <field name="link_type" type="hidden" default="0"/>
        </fieldset>
        <fieldset name="files_settings" label="JBS_ADDON_DIRECT_FILE_SETTINGS">
            <field name="player" type="hidden" default="0"/>
        </fieldset>
    </fields>
</server>
