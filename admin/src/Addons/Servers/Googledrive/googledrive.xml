<?xml version="1.0" encoding="utf-8"?>
<server type="storage" supports="*.*">
    <name>Google Drive</name>
    <description>Adapter for Google Drive document sharing and embedding. Supports Drive files, Docs, Sheets, and Slides.</description>
    <config>
        <media_resource>filename</media_resource>
    </config>
    <fields name="params">
        <fieldset name="googledrive_settings" label="JBS_ADDON_GOOGLEDRIVE_SETTINGS">
            <field name="info" type="note" label="JBS_ADDON_GOOGLEDRIVE_INFO"
                   description="JBS_ADDON_GOOGLEDRIVE_INFO_DESC" class="alert alert-info" />
        </fieldset>
    </fields>
    <fields name="media">
        <fieldset name="files_settings" label="JBS_ADDON_GOOGLEDRIVE_FILE_SETTINGS">
            <field name="player" type="list" label="JBS_MED_PLAYER"
                   description="JBS_MED_PLAYER_DESC" class="inputbox" readonly="readonly" default="1">
                <option value="1">JBS_CMN_USE_INTERNAL_PLAYER</option>
            </field>
            <field name="popup" type="list" label="JBS_MED_INTERNAL_POPUP"
                   description="JBS_MED_INTERNAL_POPUP_DESC" class="inputbox"
                   default="">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="1">JBS_CMN_POPUP</option>
                <option value="2">JBS_CMN_INLINE</option>
                <option value="3">JBS_CMN_SQUEEZEBOX</option>
            </field>
        </fieldset>
        <fieldset name="media_type" label="JBS_ADDON_GOOGLEDRIVE_MEDIA_TYPE_DEF">
            <field name="media_image" type="media" directory="biblestudy"
                   label="JBS_CMN_IMAGE" description="JBS_MED_IMAGE_DESC"
                   class="inputbox"/>
            <field name="media_use_button_icon" label="JBS_ADDON_GOOGLEDRIVE_MEDIA_USE_BUTTON"
                   description="JBS_ADDON_GOOGLEDRIVE_MEDIA_USE_BUTTON_DESC" class="inputbox" type="list" default="1">
                <option value="-1">JGLOBAL_USE_GLOBAL</option>
                <option value="">JBS_MED_NONE</option>
                <option value="1">JBS_MED_BUTTON_ONLY</option>
                <option value="2">JBS_MED_BUTTON_AND_ICON</option>
                <option value="3">JBS_MED_ICON_ONLY</option>
            </field>
            <field name="media_button_text" type="text" default="Google Drive" label="JBS_ADDON_GOOGLEDRIVE_BUTTON_TEXT"
                   description="JBS_ADDON_GOOGLEDRIVE_BUTTON_TEXT_DESC"/>
            <field name="media_button_type" type="list" class="inputbox" default=""
                   label="JBS_ADDON_GOOGLEDRIVE_BUTTON_TYPE"
                   description="JBS_ADDON_GOOGLEDRIVE_BUTTON_TYPE_DESC">
                <option value="btn-link">JBS_MED_NO_COLOR</option>
                <option value="btn-primary">JBS_MED_PRIMARY</option>
                <option value="btn-success">JBS_MED_SUCCESS</option>
                <option value="btn-info">JBS_MED_INFO</option>
                <option value="btn-warning">JBS_MED_WARNING</option>
                <option value="btn-danger">JBS_MED_DANGER</option>
            </field>
            <field name="media_button_color" type="ColorPicker" default="#4285f4"
                   description="JBS_ADDON_GOOGLEDRIVE_BUTTON_COLOR_DESC" label="JBS_ADDON_GOOGLEDRIVE_BUTTON_COLOR"/>
            <field name="media_icon_type" type="IconType" class="inputbox" default="fa-solid fa-file-lines"
                   label="JBS_ADDON_GOOGLEDRIVE_ICON_TYPE"
                   description="JBS_ADDON_GOOGLEDRIVE_ICON_TYPE_DESC">
            </field>
            <field name="media_custom_icon" type="text" default="" label="JBS_ADDON_GOOGLEDRIVE_CUSTOM_ICON"
                   description="JBS_ADDON_GOOGLEDRIVE_CUSTOM_ICON_DESC"/>
        </fieldset>
    </fields>
</server>
