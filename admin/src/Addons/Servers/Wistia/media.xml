<?xml version="1.0" encoding="utf-8"?>
<media>
    <fields name="params">
        <fieldset name="general" addfieldprefix="CWM\Component\Proclaim\Administrator\Addons\Servers\Wistia\Field">
            <field name="filename"
                   type="text"
                   label="JBS_ADDON_WISTIA_URL"
                   description="JBS_ADDON_WISTIA_URL_DISC"
                   class="inputbox"
                   required="true"/>
            <field name="wistia_browse_btn"
                   type="WistiaBrowseBtn"
                   class="wistia-browse-container"
                   label=""
                   description=""/>
            <field name="popup" type="list" label="JBS_MED_INTERNAL_POPUP"
                   description="JBS_MED_INTERNAL_POPUP_DESC"
                   class="form-select-color-state"
                   size="1"
                   default=""
                   validate="options">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="1">JBS_CMN_POPUP</option>
                <option value="2">JBS_CMN_INLINE</option>
                <option value="3">JBS_CMN_SQUEEZEBOX</option>
            </field>
        </fieldset>
        <fieldset name="details" label="JBS_ADDON_WISTIA_MEDIA_TYPE_DEF">
            <field name="media_image" type="media" directory="biblestudy"
                   label="JBS_CMN_IMAGE" description="JBS_MED_IMAGE_DESC"
                   class="inputbox">
            </field>
            <field name="media_use_button_icon" type="list"
                   class="form-select-color-state"
                   size="1"
                   default="3"
                   validate="options"
                   label="JBS_ADDON_WISTIA_MEDIA_USE_BUTTON"
                   description="JBS_ADDON_WISTIA_MEDIA_USE_BUTTON_DESC">
                <option value="-1">JBS_MED_SERVER_OPTIONS</option>
                <option value="">JBS_MED_NONE</option>
                <option value="1">JBS_MED_BUTTON_ONLY</option>
                <option value="2">JBS_MED_BUTTON_AND_ICON</option>
                <option value="3">JBS_MED_ICON_ONLY</option>
            </field>
            <field name="media_button_text" type="text" default="Wistia" label="JBS_ADDON_WISTIA_BUTTON_TEXT"
                   description="JBS_ADDON_WISTIA_BUTTON_TEXT_DESC"/>
            <field name="media_button_type" type="list"
                   class="form-select-color-state"
                   size="1"
                   default=""
                   validate="options"
                   label="JBS_ADDON_WISTIA_BUTTON_TYPE"
                   description="JBS_ADDON_WISTIA_BUTTON_TYPE_DESC">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="btn-link">JBS_MED_NO_COLOR</option>
                <option value="btn-primary">JBS_MED_PRIMARY</option>
                <option value="btn-success">JBS_MED_SUCCESS</option>
                <option value="btn-info">JBS_MED_INFO</option>
                <option value="btn-warning">JBS_MED_WARNING</option>
                <option value="btn-danger">JBS_MED_DANGER</option>
            </field>
            <field name="media_button_color" type="ColorPicker" default="#54bbff"
                   description="JBS_ADDON_WISTIA_BUTTON_COLOR_DESC" label="JBS_ADDON_WISTIA_BUTTON_COLOR"/>
            <field name="media_icon_type" type="IconType" class="form-select-color-state" size="1"
                   default="fas fa-play-circle"
                   label="JBS_ADDON_WISTIA_ICON_TYPE"
                   description="JBS_ADDON_WISTIA_ICON_TYPE_DESC">
            </field>
            <field name="media_custom_icon" type="text" default="" label="JBS_ADDON_WISTIA_CUSTOM_ICON"
                   description="JBS_ADDON_WISTIA_CUSTOM_ICON_DESC"/>
            <field name="link_type" type="hidden"
                   label="JBS_MED_SHOW_DOWNLOAD_ICON" description="JBS_MED_SHOW_DOWNLOAD_ICON_DESC"
                   class="inputbox" readonly="readonly" size="1" default="0">
                <option value="0">JBS_MED_NO_DOWNLOAD_ICON</option>
            </field>
            <field name="player" type="hidden" label="JBS_MED_PLAYER"
                   description="JBS_MED_PLAYER_DESC" class="inputbox" size="1" default="1">
                <option value="1">JBS_CMN_USE_INTERNAL_PLAYER</option>
            </field>
        </fieldset>
        <fieldset name="parameters" label="JBS_ADDON_WISTIA_PARAMETERS">
            <field name="playerwidth" default="" type="text" label="JBS_MED_PLAYERWIDTH"
                   description="JBS_MED_PLAYERWIDTH_DESC"/>
            <field name="playerheight" default="" type="text"
                   label="JBS_MED_PLAYERHIGHT" description="JBS_MED_PLAYERHIGHT_DESC"/>
            <field name="itempopuptitle" type="textarea" cols="54" rows="10" default="" filter="raw"
                   label="JBS_MED_MEDIA_POPUPTITLE" description="JBS_MED_MEDIA_POPUPTITLE_FOOTER_DESC"/>
            <field name="itempopupfooter" type="textarea" cols="54" rows="10" default="" filter="raw"
                   label="JBS_MED_MEDIA_POPUPFOOTER" description="JBS_MED_MEDIA_POPUPTITLE_FOOTER_DESC"/>
            <field name="popupmargin" type="text" default="50"
                   label="JBS_MED_MEDIA_POPUPMARGIN" description="JBS_MED_MEDIA_POPUPMARGIN_DESC"/>
            <field name="autostart" type="list"
                   label="JBS_CMN_MEDIA_AUTOSTART" description="JBS_CMN_MEDIA_AUTOSTART_DESC" default="">
                <option value="">JGLOBAL_USE_GLOBAL</option>
                <option value="true">JYES</option>
                <option value="false">JNO</option>
            </field>
        </fieldset>
        <fieldset name="embed_options" label="JBS_ADDON_WISTIA_EMBED_OPTIONS">
            <field name="ws_muted" type="list" default=""
                   label="JBS_ADDON_WISTIA_MUTED" description="JBS_ADDON_WISTIA_MUTED_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JNO</option>
                <option value="true">JYES</option>
            </field>
            <field name="ws_player_color" type="text" default=""
                   label="JBS_ADDON_WISTIA_PLAYER_COLOR" description="JBS_ADDON_WISTIA_PLAYER_COLOR_DESC"
                   hint="e.g. 54bbff"/>
            <field name="ws_controls_visible" type="list" default=""
                   label="JBS_ADDON_WISTIA_CONTROLS_VISIBLE" description="JBS_ADDON_WISTIA_CONTROLS_VISIBLE_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JHIDE</option>
                <option value="true">JSHOW</option>
            </field>
            <field name="ws_playbar" type="list" default=""
                   label="JBS_ADDON_WISTIA_PLAYBAR" description="JBS_ADDON_WISTIA_PLAYBAR_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JHIDE</option>
                <option value="true">JSHOW</option>
            </field>
            <field name="ws_end_behavior" type="list" default=""
                   label="JBS_ADDON_WISTIA_END_BEHAVIOR" description="JBS_ADDON_WISTIA_END_BEHAVIOR_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="default">JBS_ADDON_WISTIA_END_DEFAULT</option>
                <option value="reset">JBS_ADDON_WISTIA_END_RESET</option>
                <option value="loop">JBS_ADDON_WISTIA_END_LOOP</option>
            </field>
            <field name="ws_dnt" type="list" default=""
                   label="JBS_ADDON_WISTIA_DNT" description="JBS_ADDON_WISTIA_DNT_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JNO</option>
                <option value="true">JYES</option>
            </field>
            <field name="ws_time" type="text" default=""
                   label="JBS_ADDON_WISTIA_TIME" description="JBS_ADDON_WISTIA_TIME_DESC"
                   hint="e.g. 30"/>
            <field name="ws_resumable" type="list" default=""
                   label="JBS_ADDON_WISTIA_RESUMABLE" description="JBS_ADDON_WISTIA_RESUMABLE_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JNO</option>
                <option value="true">JYES</option>
                <option value="auto">JBS_ADDON_WISTIA_RESUMABLE_AUTO</option>
            </field>
            <field name="ws_speed" type="list" default=""
                   label="JBS_ADDON_WISTIA_SPEED" description="JBS_ADDON_WISTIA_SPEED_DESC">
                <option value="">JBS_ADDON_PLATFORM_DEFAULT</option>
                <option value="false">JNO</option>
                <option value="true">JYES</option>
            </field>
        </fieldset>
    </fields>
</media>
